    <script>
        function secretSearch(event) {
            event.preventDefault(); 
            const keyword = document.getElementById('search-keyword').value;

            if (keyword === "admin_pass") {
                window.location.href = "/mitaka-kenji-blog/hidden/admin/login.html";
            } else {
                // search.htmlにキーワードを渡す
                window.location.href = "/mitaka-kenji-blog/search.html?q=" + encodeURIComponent(keyword);
            }
        }
        const glitchChars = "¡¢£¤¥¦§¨©ª«¬®¯°±²³´µ¶·¸¹º»¼½¾¿ÀÁÂÃÄÅÆÇÈÉÊËÌÍÎÏÐÑÒÓÔÕÖ×ØÙÚÛÜÝÞßàáâãäåæçèéêëìíîïðñòóôõö÷øùúûüýþÿ!@#$%^&*";

        // 2. 目印（class="glitch-text"）のついた要素をすべて取得
        const glitchElements = document.querySelectorAll('.glitch-text');

        // 各要素について、元のテキストを保存しておく
        glitchElements.forEach(el => {
            el.dataset.originalText = el.textContent;
        });

        // 3. 文字をランダムに化けさせるメインの関数
        function doGlitch() {
            // 目印がついた要素の中から、ランダムに1つ選ぶ
            const targetElement = glitchElements[Math.floor(Math.random() * glitchElements.length)];
            const originalText = targetElement.dataset.originalText;
            
            // 文字を分解
            let textArray = originalText.split('');
            
            // 何文字化けさせるか（全文字数の10%〜30%くらいがおすすめ）
            const glitchAmount = Math.floor(textArray.length * 0.15); 

            // ランダムに選んだ文字を化け文字に置き換える
            for (let i = 0; i < glitchAmount; i++) {
                const randomIndex = Math.floor(Math.random() * textArray.length);
                // スペース（空白）は化けさせないほうが読みやすい
                if (textArray[randomIndex] !== ' ') {
                    textArray[randomIndex] = glitchChars[Math.floor(Math.random() * glitchChars.length)];
                }
            }

            // 化けたテキストを表示
            targetElement.textContent = textArray.join('');

            // 【超重要】一瞬（例えば150ミリ秒）後に、元のテキストに戻す
            setTimeout(() => {
                targetElement.textContent = originalText;
            }, 150);
        }

        // 4. エフェクトを実行するタイミングを制御する関数（不規則にする）
        function scheduleNextGlitch() {
            // 次のエフェクトまでの待ち時間をランダムに設定（例：3秒〜10秒の間）
            const nextDelay = Math.random() * (10000 - 3000) + 3000;

            setTimeout(() => {
                doGlitch(); // エフェクト実行
                scheduleNextGlitch(); // 終わったら、また次の実行を予約（ループさせる）
            }, nextDelay);
        }

        // サイトが表示されたら、不規則なループを開始
        if (glitchElements.length > 0) {
            scheduleNextGlitch();
        }
    </script>
